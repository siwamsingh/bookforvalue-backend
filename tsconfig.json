{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": "src",
    "outDir": "dist",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "types": ["node"],

    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src"]
}